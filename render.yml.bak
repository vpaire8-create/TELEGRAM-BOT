services:
  - type: web
    name: facebook-telegram-bot
    runtime: python
    plan: free
    buildCommand: |
      apt-get update
      apt-get install -y chromium chromium-driver
      pip install -r requirements.txt
    startCommand: python bot.py
    envVars:
      - key: TELEGRAM_BOT_TOKEN
        sync: false
      - key: ADMIN_USER_IDS
        sync: false
      - key: OWNER_FACEBOOK
        sync: false
      - key: DATA_DIR
        value: /opt/render/project/outputs
    disk:
      name: data
      mountPath: /opt/render/project/outputs
      sizeGB: 1
